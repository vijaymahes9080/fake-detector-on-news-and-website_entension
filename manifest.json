{
    "manifest_version": 3,
    "name": "TruthGuard: Fake News Detector",
    "version": "1.0",
    "description": "Detects fake news and websites with unique level icons and real‑world impact metrics.",
    "permissions": [
        "activeTab",
        "storage",
        "scripting"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "icons": {
        "16": "icons/low.png",
        "48": "icons/medium.png",
        "128": "icons/icon.png"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}